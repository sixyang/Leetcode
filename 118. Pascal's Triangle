class Solution:
    def generate(self, numRows: int) -> List[List[int]]:
        nums = [[1 for j in range(i+1)] for i in range(numRows)]

        for i in range(numRows):
            m = i
            n = 1
            while n < m:
                if n != m:
                    nums[m][n] = nums[m-1][n-1] + nums[m-1][n]       
                n += 1
        return nums
